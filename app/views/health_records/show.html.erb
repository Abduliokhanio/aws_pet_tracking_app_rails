<p style="color: green"><%= notice %></p>

<div class="show-container">
  <h1>Health Record Details</h1>
  
  <%= render @health_record %>

  <% if @health_record.medication.present? %>
    <div class="card">
      <h3>Associated Medication</h3>
      <div>
        <strong>Name:</strong> <%= @health_record.medication.medication_name %>
      </div>
      <div>
        <strong>Dose:</strong> <%= @health_record.medication.dose %>
      </div>
      <div>
        <strong>Start Date:</strong> <%= @health_record.medication.start_date.strftime("%B %d, %Y") %>
      </div>
      <% if @health_record.medication.end_date.present? %>
        <div>
          <strong>End Date:</strong> <%= @health_record.medication.end_date.strftime("%B %d, %Y") %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_pet_health_record_path(@pet, @health_record), class: "btn-edit" %>
    <%= link_to "📋 Back to Health Records", pet_health_records_path(@pet), class: "btn-back" %>
    <%= button_to "🗑️ Delete", [@pet, @health_record], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this health record?" } } %>
  </div>
</div>
