<p style="color: green"><%= notice %></p>

<% content_for :title, "Health Records" %>

<div class="page-header">
  <h1>📊 Health Records</h1>
  <p class="page-subtitle">Health tracking for <%= @pet.name %></p>
  <div style="margin-top: 10px;">
    <%= link_to "📥 Export to CSV", export_pet_health_records_path(@pet, format: :csv), class: "btn-secondary" %>
  </div>
</div>

<% if @visualization_data.present? %>
  <div class="card">
    <h2>Weight Trend</h2>
    <div style="position: relative; height: 400px;">
      <canvas id="weightChart" data-chart-data="<%= @visualization_data.to_json %>"></canvas>
    </div>
  </div>
<% end %>

<% if @health_metrics_data.present? && (@health_metrics_data[:mood].present? || @health_metrics_data[:activity_level].present? || @health_metrics_data[:food_intake].present?) %>
  <div class="card">
    <h2>Health Metrics</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
      <% if @health_metrics_data[:mood].present? %>
        <div style="position: relative; height: 300px;">
          <canvas id="moodChart" data-metrics-data="<%= @health_metrics_data.to_json %>"></canvas>
        </div>
      <% end %>
      
      <% if @health_metrics_data[:activity_level].present? %>
        <div style="position: relative; height: 300px;">
          <canvas id="activityChart" data-metrics-data="<%= @health_metrics_data.to_json %>"></canvas>
        </div>
      <% end %>
      
      <% if @health_metrics_data[:food_intake].present? %>
        <div style="position: relative; height: 300px;">
          <canvas id="foodIntakeChart" data-metrics-data="<%= @health_metrics_data.to_json %>"></canvas>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div id="health_records">
  <% @health_records.each do |health_record| %>
    <div class="card">
      <%= render health_record %>
      <div class="card-actions">
        <%= link_to "View Details", pet_health_record_path(@pet, health_record), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @health_records.any? %>">
  <p>📝 No health records yet. Add the first health record!</p>
</div>

<%= paginate @health_records if @health_records.respond_to?(:current_page) %>

<div class="floating-action">
  <%= link_to "➕ New Health Record", new_pet_health_record_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
