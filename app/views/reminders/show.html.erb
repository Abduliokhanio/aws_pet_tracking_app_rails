<p style="color: green"><%= notice %></p>

<div class="show-container">
  <h1>Reminder Details</h1>
  
  <%= render @reminder %>

  <div class="action-buttons">
    <% unless @reminder.completed_at.present? %>
      <%= button_to "✓ Mark Complete", complete_pet_reminder_path(@pet, @reminder), method: :post, class: "btn-edit", style: "background: #4CAF50;" %>
    <% end %>
    <%= link_to "✏️ Edit", edit_pet_reminder_path(@pet, @reminder), class: "btn-edit" %>
    <%= link_to "📋 Back to Reminders", pet_reminders_path(@pet), class: "btn-back" %>
    <%= button_to "🗑️ Delete", [@pet, @reminder], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this reminder?" } } %>
  </div>
</div>
