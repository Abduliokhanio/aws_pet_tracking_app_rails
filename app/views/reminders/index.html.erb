<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<% content_for :title, "Reminders" %>

<style>
  .dashboard-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  
  .dashboard-nav-btn {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 15px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .dashboard-nav-btn:hover {
    background: rgba(0, 212, 255, 0.2);
    border-color: #00d4ff;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    transform: translateY(-3px);
  }
  
  .dashboard-nav-btn.active {
    background: linear-gradient(135deg, #7b2cbf, #5a189a);
    border-color: #9d4edd;
    color: #e0e0e0;
  }
</style>

<div class="page-header">
  <h1>🔔 Reminders</h1>
  <p class="page-subtitle">Reminders for <%= @pet.name %></p>
</div>

<!-- Navigation Tabs -->
<div class="dashboard-nav">
  <%= link_to pet_health_records_path(@pet), class: "dashboard-nav-btn" do %>
    📊 Health Records
  <% end %>
  <%= link_to pet_medications_path(@pet), class: "dashboard-nav-btn" do %>
    💊 Medications
  <% end %>
  <%= link_to pet_reminders_path(@pet), class: "dashboard-nav-btn active" do %>
    ⏰ Reminders
  <% end %>
  <%= link_to dashboard_user_pet_path(@user, @pet), class: "dashboard-nav-btn" do %>
    🏠 Health Dashboard
  <% end %>
</div>

<h2 style="color: #d32f2f;">Due Reminders</h2>
<div id="due_reminders">
  <% @due_reminders.each do |reminder| %>
    <div class="card" style="border-left: 4px solid #d32f2f;">
      <%= render reminder %>
      <div class="card-actions">
        <%= link_to "View Details", pet_reminder_path(@pet, reminder), class: "btn-card" %>
        <%= button_to "✓ Complete", complete_pet_reminder_path(@pet, reminder), method: :post, class: "btn-card", style: "background: #4CAF50;" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @due_reminders.any? %>">
  <p>✓ No due reminders!</p>
</div>

<h2 style="color: #1976d2;">Upcoming Reminders</h2>
<div id="upcoming_reminders">
  <% @upcoming_reminders.each do |reminder| %>
    <div class="card" style="border-left: 4px solid #1976d2;">
      <%= render reminder %>
      <div class="card-actions">
        <%= link_to "View Details", pet_reminder_path(@pet, reminder), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @upcoming_reminders.any? %>">
  <p>📅 No upcoming reminders.</p>
</div>

<h2 style="color: #757575;">Completed Reminders</h2>
<div id="completed_reminders">
  <% @completed_reminders.each do |reminder| %>
    <div class="card" style="opacity: 0.7; border-left: 4px solid #757575;">
      <%= render reminder %>
      <div class="card-actions">
        <%= link_to "View Details", pet_reminder_path(@pet, reminder), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @completed_reminders.any? %>">
  <p>📋 No completed reminders.</p>
</div>

<div class="floating-action">
  <%= link_to "➕ New Reminder", new_pet_reminder_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
