<%= form_with(model: veterinarian) do |form| %>
  <% if veterinarian.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(veterinarian.errors.count, "error") %> prohibited this veterinarian from being saved:</h2>

      <ul>
        <% veterinarian.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name, required: true %>
  </div>

  <div>
    <%= form.label :vet_office_id, "Vet Office", style: "display: block" %>
    <%= form.collection_select :vet_office_id, VetOffice.all, :id, :name, { prompt: 'Select a vet office' }, required: true %>
  </div>

  <div>
    <%= form.label :years_of_experience, style: "display: block" %>
    <%= form.number_field :years_of_experience, min: 0 %>
  </div>

  <div>
    <%= form.label :work_history, style: "display: block" %>
    <%= form.text_area :work_history, rows: 5 %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
