<p style="color: green"><%= notice %></p>

<div class="show-container">
  <%= render @pet %>

  <div class="card" style="margin: 2rem 0; position: relative;">
    <h3 style="color: #00d4ff; text-shadow: 0 0 15px rgba(0, 212, 255, 0.4); margin-bottom: 1.5rem; text-align: center; position: relative; z-index: 2;">🏥 Health Management</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; position: relative; z-index: 2;">
      <%= link_to dashboard_user_pet_path(@user, @pet), style: "background: linear-gradient(135deg, #7b2cbf, #5a189a); border: 2px solid #9d4edd; color: #e0e0e0; text-align: center; padding: 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; display: block; cursor: pointer; position: relative; z-index: 10;", onmouseover: "this.style.transform='translateY(-3px)'; this.style.boxShadow='0 0 25px rgba(157, 78, 221, 0.6)';", onmouseout: "this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
        🏠 Health Dashboard
      <% end %>
      <%= link_to pet_health_records_path(@pet), style: "background: rgba(0, 212, 255, 0.1); border: 2px solid #00d4ff; color: #00d4ff; text-align: center; padding: 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; display: block; cursor: pointer; position: relative; z-index: 10;", onmouseover: "this.style.background='rgba(0, 212, 255, 0.2)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 0 20px rgba(0, 212, 255, 0.4)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
        📊 Health Records
      <% end %>
      <%= link_to pet_medications_path(@pet), style: "background: rgba(0, 212, 255, 0.1); border: 2px solid #00d4ff; color: #00d4ff; text-align: center; padding: 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; display: block; cursor: pointer; position: relative; z-index: 10;", onmouseover: "this.style.background='rgba(0, 212, 255, 0.2)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 0 20px rgba(0, 212, 255, 0.4)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
        💊 Medications
      <% end %>
      <%= link_to pet_reminders_path(@pet), style: "background: rgba(0, 212, 255, 0.1); border: 2px solid #00d4ff; color: #00d4ff; text-align: center; padding: 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease; display: block; cursor: pointer; position: relative; z-index: 10;", onmouseover: "this.style.background='rgba(0, 212, 255, 0.2)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 0 20px rgba(0, 212, 255, 0.4)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
        ⏰ Reminders
      <% end %>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr auto; gap: 1rem; margin: 2rem 0; align-items: center;">
    <%= link_to edit_user_pet_path(@user, @pet), style: "color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 25px; background: rgba(0, 212, 255, 0.1); font-weight: 600; font-size: 1rem; transition: all 0.3s ease; cursor: pointer; display: block; text-align: center;", onmouseover: "this.style.background='#00d4ff'; this.style.color='#0a0e27'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0 20px rgba(0, 212, 255, 0.6)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.color='#00d4ff'; this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
      ✏️ Edit
    <% end %>
    <%= link_to user_pets_path, style: "color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 25px; background: rgba(0, 212, 255, 0.1); font-weight: 600; font-size: 1rem; transition: all 0.3s ease; cursor: pointer; display: block; text-align: center;", onmouseover: "this.style.background='#00d4ff'; this.style.color='#0a0e27'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0 20px rgba(0, 212, 255, 0.6)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.color='#00d4ff'; this.style.transform='translateY(0)'; this.style.boxShadow='none';" do %>
      📋 Back to Pets
    <% end %>
    <%= button_to "🗑️ Delete Pet", [@user, @pet], method: :delete, style: "background: linear-gradient(135deg, #c9184a, #a4133c); border: 2px solid #ff4d6d; color: #e0e0e0; padding: 1rem 2rem; border-radius: 25px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; width: 100%;", onmouseover: "this.style.background='linear-gradient(135deg, #ff4d6d, #c9184a)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 0 30px rgba(255, 77, 109, 0.6)';", onmouseout: "this.style.background='linear-gradient(135deg, #c9184a, #a4133c)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';", form: { data: { turbo_confirm: "Are you sure you want to delete this pet?" } } %>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns: 1fr 1fr auto"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
