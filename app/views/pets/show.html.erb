<p style="color: green"><%= notice %></p>

<div class="show-container">
  <%= render @pet %>

  <div class="card" style="margin: 2rem 0;">
    <h3 style="color: #00d4ff; text-shadow: 0 0 15px rgba(0, 212, 255, 0.4); margin-bottom: 1.5rem; text-align: center;">🏥 Health Management</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
      <%= link_to dashboard_user_pet_path(@user, @pet), class: "btn-card", style: "background: linear-gradient(135deg, #7b2cbf, #5a189a); border-color: #9d4edd; color: #e0e0e0; text-align: center; padding: 1rem;" do %>
        🏠 Health Dashboard
      <% end %>
      <%= link_to pet_health_records_path(@pet), class: "btn-card", style: "text-align: center; padding: 1rem;" do %>
        📊 Health Records
      <% end %>
      <%= link_to pet_medications_path(@pet), class: "btn-card", style: "text-align: center; padding: 1rem;" do %>
        💊 Medications
      <% end %>
      <%= link_to pet_reminders_path(@pet), class: "btn-card", style: "text-align: center; padding: 1rem;" do %>
        ⏰ Reminders
      <% end %>
    </div>
  </div>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_user_pet_path(@user, @pet), class: "btn-edit" %>
    <%= link_to "📋 Back to Pets", user_pets_path, class: "btn-back" %>
    <%= button_to "🗑️ Delete Pet", [@user, @pet], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this pet?" } } %>
  </div>
</div>
