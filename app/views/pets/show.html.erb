<p style="color: green"><%= notice %></p>

<div class="show-container">
  <%= render @pet %>

  <div class="health-management-section" style="margin: 2rem 0; padding: 1.5rem; background: #f8f9fa; border-radius: 8px;">
    <h3 style="margin-bottom: 1rem;">🏥 Health Management</h3>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <%= link_to "🏠 Health Dashboard", dashboard_user_pet_path(@user, @pet), class: "btn-primary", style: "background: #4caf50;" %>
      <%= link_to "📊 Health Records", pet_health_records_path(@pet), class: "btn-primary" %>
      <%= link_to "💊 Medications", pet_medications_path(@pet), class: "btn-primary" %>
      <%= link_to "⏰ Reminders", pet_reminders_path(@pet), class: "btn-primary" %>
    </div>
  </div>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_user_pet_path(@user, @pet), class: "btn-edit" %>
    <%= link_to "📋 Back to Pets", user_pets_path, class: "btn-back" %>
    <%= button_to "🗑️ Delete Pet", [@user, @pet], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this pet?" } } %>
  </div>
</div>
