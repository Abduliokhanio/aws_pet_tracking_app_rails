<p style="color: green"><%= notice %></p>

<% content_for :title, "Pets" %>

<h1>Pets</h1>

<div id="pets">
  <% @pets.each do |pet| %>
    <%= render pet %>
    <p>
      <%= link_to "Show this pet", [@user, pet] %>
    </p>
  <% end %>
</div>

<%= link_to "New pet", new_user_pet_path %>

<%= link_to "Users", users_path %>

