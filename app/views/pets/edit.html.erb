<% content_for :title, "Editing pet" %>

<div class="page-header">
  <h1>✏️ Edit Pet</h1>
  <p class="page-subtitle">Update pet information</p>
</div>

<%= render "form", pet: @pet %>

<div class="form-actions">
  <%= link_to "👁️ View Pet", [@user, @pet], class: "btn-secondary" %>
  <%= link_to "📋 Back to Pets", user_pets_path, class: "btn-secondary" %>
</div>
