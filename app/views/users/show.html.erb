<p style="color: green"><%= notice %></p>

<div class="show-container">
  <%= render @user %>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_user_path(@user), class: "btn-edit" %>
    <%= link_to "📋 Back to Users", users_path, class: "btn-back" %>
    <%= link_to "🐾 View Pets", user_pets_path(@user), class: "btn-pets" %>
    <%= button_to "🗑️ Delete User", @user, method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this user and all their pets?" } } %>
  </div>
</div>
