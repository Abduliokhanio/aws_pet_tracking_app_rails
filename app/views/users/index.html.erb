<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<% content_for :title, "Users" %>

<div class="page-header">
  <h1>👥 Users</h1>
  <p class="page-subtitle">Manage all registered users</p>
</div>

<div id="users">
  <% @users.each do |user| %>
    <div class="card">
      <%= render user %>
      <div class="card-actions">
        <%= link_to "View Details", user, class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @users.any? %>">
  <p>🌟 No users yet. Create your first user to get started!</p>
</div>

<div class="floating-action">
  <%= link_to "➕ New User", new_user_path, class: "btn-floating" %>
</div>
