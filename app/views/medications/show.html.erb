<p style="color: green"><%= notice %></p>

<div class="show-container">
  <h1>Medication Details</h1>
  
  <%= render @medication %>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_pet_medication_path(@pet, @medication), class: "btn-edit" %>
    <%= link_to "📋 Back to Medications", pet_medications_path(@pet), class: "btn-back" %>
    <%= button_to "🗑️ Delete", [@pet, @medication], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this medication?" } } %>
  </div>
</div>
