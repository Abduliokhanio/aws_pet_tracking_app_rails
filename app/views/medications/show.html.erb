<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<style>
  .medication-detail-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .medication-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .medication-title {
    font-size: 2.5rem;
    color: #00d4ff;
    text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
    margin-bottom: 0.5rem;
  }
  
  .medication-subtitle {
    color: rgba(0, 212, 255, 0.7);
    font-size: 1.1rem;
  }
  
  .info-card {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    border-radius: 15px;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  
  .info-item {
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    border-left: 4px solid #00d4ff;
  }
  
  .info-label {
    color: rgba(224, 224, 224, 0.7);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  
  .info-value {
    color: #00d4ff;
    font-size: 1.2rem;
    font-weight: 600;
  }
</style>

<div class="medication-detail-container">
  <div class="medication-header">
    <h1 class="medication-title">💊 <%= @medication.medication_name %></h1>
    <p class="medication-subtitle">Medication details for <%= @pet.name %></p>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📋 Medication Information</h2>
    <div class="info-grid">
      <div class="info-item">
        <div class="info-label">Dosage</div>
        <div class="info-value"><%= @medication.dose %> mg</div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Start Date</div>
        <div class="info-value"><%= @medication.start_date.strftime("%b %d, %Y") %></div>
      </div>
      
      <div class="info-item">
        <div class="info-label">End Date</div>
        <div class="info-value"><%= @medication.end_date ? @medication.end_date.strftime("%b %d, %Y") : "Ongoing" %></div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Status</div>
        <div class="info-value">
          <% if @medication.active? %>
            <span style="color: #00ff88;">✓ Active</span>
          <% else %>
            <span style="color: #999;">✗ Inactive</span>
          <% end %>
        </div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Duration</div>
        <div class="info-value">
          <% 
            start_date = @medication.start_date
            end_date = @medication.end_date || Date.today
            days = (end_date - start_date).to_i
          %>
          <%= days %> days
        </div>
      </div>
    </div>
    
    <% if @medication.notes.present? %>
      <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(0, 0, 0, 0.3); border-radius: 10px;">
        <div class="info-label">Notes</div>
        <div style="color: #e0e0e0; margin-top: 0.5rem;"><%= @medication.notes %></div>
      </div>
    <% end %>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📊 Dosage Timeline</h2>
    <div style="position: relative; height: 300px;">
      <canvas id="medicationUsageChart"></canvas>
    </div>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📝 Dosage History</h2>
    <% if @medication.medication_dosages.any? %>
      <div style="display: grid; gap: 1rem;">
        <% @medication.medication_dosages.ordered.each do |dosage| %>
          <div style="padding: 1.5rem; background: rgba(0, 0, 0, 0.3); border-radius: 10px; border-left: 4px solid #00d4ff; display: flex; justify-content: space-between; align-items: center;">
            <div style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                <div style="color: #00d4ff; font-weight: 600; font-size: 1.3rem;">
                  <%= dosage.dose %> mg
                </div>
                <div style="color: rgba(224, 224, 224, 0.7); font-size: 0.95rem;">
                  📅 <%= dosage.recorded_on.strftime("%B %d, %Y") %>
                </div>
              </div>
              <% if dosage.notes.present? %>
                <div style="color: rgba(224, 224, 224, 0.8); margin-top: 0.5rem; font-size: 0.95rem;">
                  💬 <%= dosage.notes %>
                </div>
              <% end %>
            </div>
            <div style="display: flex; gap: 0.5rem;">
              <%= link_to "✏️", edit_pet_medication_medication_dosage_path(@pet, @medication, dosage), style: "background: rgba(0, 212, 255, 0.2); border: 1px solid #00d4ff; color: #00d4ff; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-size: 1.2rem; transition: all 0.3s ease;", onmouseover: "this.style.background='rgba(0, 212, 255, 0.4)';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.2)';" %>
              <%= button_to "🗑️", pet_medication_medication_dosage_path(@pet, @medication, dosage), method: :delete, style: "background: rgba(255, 77, 109, 0.2); border: 1px solid #ff4d6d; color: #ff4d6d; padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 1.2rem; transition: all 0.3s ease;", onmouseover: "this.style.background='rgba(255, 77, 109, 0.4)';", onmouseout: "this.style.background='rgba(255, 77, 109, 0.2)';", form: { data: { turbo_confirm: "Delete this dosage record?" } } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 2rem; background: rgba(0, 0, 0, 0.2); border-radius: 10px; border: 2px dashed rgba(0, 212, 255, 0.3);">
        <p style="color: rgba(224, 224, 224, 0.5); font-size: 1.1rem;">📋 No dosage history recorded yet.</p>
        <p style="color: rgba(224, 224, 224, 0.4); font-size: 0.9rem; margin-top: 0.5rem;">Add your first dosage record below</p>
      </div>
    <% end %>
    
    <div style="margin-top: 1.5rem; text-align: center;">
      <%= link_to new_pet_medication_medication_dosage_path(@pet, @medication), style: "display: inline-block; color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 15px; background: rgba(0, 212, 255, 0.1); font-weight: 600; transition: all 0.3s ease;", onmouseover: "this.style.background='#00d4ff'; this.style.color='#0a0e27';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.color='#00d4ff';" do %>
        ➕ Add Dosage Change
      <% end %>
    </div>
  </div>

  <script>
    // Use DOMContentLoaded instead of turbo:load for more reliable execution
    (function() {
      function initChart() {
        console.log('Init chart function called');
        console.log('Chart available:', typeof Chart);
        
        const canvas = document.getElementById('medicationUsageChart');
        if (!canvas) {
          console.log('Canvas not found');
          return;
        }
        
        console.log('Canvas found');
        
        // Wait for Chart.js to be available
        if (typeof Chart === 'undefined') {
          console.log('Chart not ready, waiting...');
          setTimeout(initChart, 100);
          return;
        }
        
        console.log('Chart.js is ready, creating chart');
        
        const startDate = new Date('<%= @medication.start_date.iso8601 %>');
        const endDate = <%= @medication.end_date ? "new Date('#{@medication.end_date.iso8601}')" : 'new Date()' %>;
        
        // Get dosage history from the backend
        const dosageHistory = <%= raw @medication.medication_dosages.ordered.map { |d| { date: d.recorded_on.iso8601, dose: d.dose.to_f } }.to_json %>;
        
        console.log('Dosage history:', dosageHistory);
        
        // If no dosage history, use the medication's current dose
        if (dosageHistory.length === 0) {
          dosageHistory.push({
            date: '<%= @medication.start_date.iso8601 %>',
            dose: <%= @medication.dose %>
          });
        }
        
        // Generate data points with dosage changes
        const labels = [];
        const data = [];
        let currentDate = new Date(startDate);
        let currentDosageIndex = 0;
        let currentDose = dosageHistory[0].dose;
        
        while (currentDate <= endDate) {
          const dateStr = currentDate.toISOString().split('T')[0];
          
          // Check if there's a dosage change on this date
          for (let i = currentDosageIndex; i < dosageHistory.length; i++) {
            if (dosageHistory[i].date === dateStr) {
              currentDose = dosageHistory[i].dose;
              currentDosageIndex = i + 1;
              break;
            } else if (new Date(dosageHistory[i].date) > currentDate) {
              break;
            }
          }
          
          labels.push(currentDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }));
          data.push(currentDose);
          currentDate.setDate(currentDate.getDate() + 1);
        }
        
        console.log('Data points:', labels.length);
        
        const ctx = canvas.getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Daily Dosage (mg)',
              data: data,
              borderColor: '#00d4ff',
              backgroundColor: 'rgba(0, 212, 255, 0.2)',
              fill: true,
              tension: 0.4,
              pointRadius: 3,
              pointHoverRadius: 6,
              borderWidth: 3
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { 
                display: true,
                labels: { color: '#00d4ff' }
              },
              title: {
                display: true,
                text: 'Medication Dosage Over Time',
                color: '#00d4ff',
                font: { size: 16 }
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#00d4ff',
                bodyColor: '#e0e0e0',
                borderColor: '#00d4ff',
                borderWidth: 1,
                callbacks: {
                  label: function(context) {
                    return 'Dosage: ' + context.parsed.y + ' mg';
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                title: {
                  display: true,
                  text: 'Dosage (mg)',
                  color: '#00d4ff'
                },
                ticks: {
                  color: '#e0e0e0',
                  callback: function(value) {
                    return value + ' mg';
                  }
                },
                grid: {
                  color: 'rgba(0, 212, 255, 0.1)'
                }
              },
              x: {
                title: {
                  display: true,
                  text: 'Date',
                  color: '#00d4ff'
                },
                ticks: {
                  color: '#e0e0e0',
                  maxRotation: 45,
                  minRotation: 45,
                  maxTicksLimit: 10
                },
                grid: {
                  color: 'rgba(0, 212, 255, 0.1)'
                }
              }
            }
          }
        });
        
        console.log('Chart created!');
      }
      
      // Try multiple event listeners
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initChart);
      } else {
        initChart();
      }
      
      document.addEventListener('turbo:load', initChart);
      document.addEventListener('turbo:render', initChart);
    })();
  </script>
    <%= link_to edit_pet_medication_path(@pet, @medication), style: "color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 25px; background: rgba(0, 212, 255, 0.1); font-weight: 600; transition: all 0.3s ease; cursor: pointer;", onmouseover: "this.style.background='#00d4ff'; this.style.color='#0a0e27';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.color='#00d4ff';" do %>
      ✏️ Edit
    <% end %>
    <%= link_to pet_medications_path(@pet), style: "color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 25px; background: rgba(0, 212, 255, 0.1); font-weight: 600; transition: all 0.3s ease; cursor: pointer;", onmouseover: "this.style.background='#00d4ff'; this.style.color='#0a0e27';", onmouseout: "this.style.background='rgba(0, 212, 255, 0.1)'; this.style.color='#00d4ff';" do %>
      📋 Back to Medications
    <% end %>
    <%= button_to "🗑️ Delete", [@pet, @medication], method: :delete, style: "background: linear-gradient(135deg, #c9184a, #a4133c); border: 2px solid #ff4d6d; color: #e0e0e0; padding: 1rem 2rem; border-radius: 25px; font-weight: 600; cursor: pointer; transition: all 0.3s ease;", onmouseover: "this.style.background='linear-gradient(135deg, #ff4d6d, #c9184a)';", onmouseout: "this.style.background='linear-gradient(135deg, #c9184a, #a4133c)';", form: { data: { turbo_confirm: "Are you sure you want to delete this medication?" } } %>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', () => {
    console.log('Medication timeline script loading, Chart available:', typeof Chart !== 'undefined');
    
    const canvas = document.getElementById('medicationUsageChart');
    if (!canvas) {
      console.log('Canvas not found');
      return;
    }
    
    console.log('Canvas found, checking Chart...');
    
    if (typeof Chart === 'undefined') {
      console.error('Chart.js is not loaded!');
      return;
    }
    
    const startDate = new Date('<%= @medication.start_date.iso8601 %>');
    const endDate = <%= @medication.end_date ? "new Date('#{@medication.end_date.iso8601}')" : 'new Date()' %>;
    const today = new Date();
    
    console.log('Dates:', { startDate, endDate, today });
    
    // Generate daily data points
    const labels = [];
    const data = [];
    let currentDate = new Date(startDate);
    
    while (currentDate <= endDate && currentDate <= today) {
      labels.push(currentDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      data.push(1); // 1 indicates medication was active on this day
      currentDate.setDate(currentDate.getDate() + 1);
    }
    
    console.log('Chart data prepared:', { labels: labels.length, data: data.length });
    
    const ctx = canvas.getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [{
          label: 'Medication Active',
          data: data,
          borderColor: '#00d4ff',
          backgroundColor: 'rgba(0, 212, 255, 0.2)',
          fill: true,
          stepped: true,
          pointRadius: 0,
          borderWidth: 3
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: false
          },
          title: {
            display: true,
            text: 'Medication Usage Timeline',
            color: '#00d4ff',
            font: { size: 16 }
          },
          tooltip: {
            backgroundColor: 'rgba(0, 0, 0, 0.8)',
            titleColor: '#00d4ff',
            bodyColor: '#e0e0e0',
            borderColor: '#00d4ff',
            borderWidth: 1,
            callbacks: {
              label: function(context) {
                return 'Medication Active';
              }
            }
          }
        },
        scales: {
          y: {
            display: false,
            min: 0,
            max: 1.5
          },
          x: {
            ticks: {
              color: '#e0e0e0',
              maxRotation: 45,
              minRotation: 45,
              maxTicksLimit: 10
            },
            grid: {
              color: 'rgba(0, 212, 255, 0.1)'
            }
          }
        }
      }
    });
    
    console.log('Chart created successfully');
  });
</script>
