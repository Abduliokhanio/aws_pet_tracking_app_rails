<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<style>
  .medication-detail-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .medication-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .medication-title {
    font-size: 2.5rem;
    color: #00d4ff;
    text-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
    margin-bottom: 0.5rem;
  }
  
  .medication-subtitle {
    color: rgba(0, 212, 255, 0.7);
    font-size: 1.1rem;
  }
  
  .info-card {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    border-radius: 15px;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  
  .info-item {
    padding: 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 10px;
    border-left: 4px solid #00d4ff;
  }
  
  .info-label {
    color: rgba(224, 224, 224, 0.7);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  
  .info-value {
    color: #00d4ff;
    font-size: 1.2rem;
    font-weight: 600;
  }
</style>

<div class="medication-detail-container">
  <div class="medication-header">
    <h1 class="medication-title">💊 <%= @medication.medication_name %></h1>
    <p class="medication-subtitle">Medication details for <%= @pet.name %></p>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📋 Medication Information</h2>
    <div class="info-grid">
      <div class="info-item">
        <div class="info-label">Dosage</div>
        <div class="info-value"><%= @medication.dose %> mg</div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Start Date</div>
        <div class="info-value"><%= @medication.start_date.strftime("%b %d, %Y") %></div>
      </div>
      
      <div class="info-item">
        <div class="info-label">End Date</div>
        <div class="info-value"><%= @medication.end_date ? @medication.end_date.strftime("%b %d, %Y") : "Ongoing" %></div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Status</div>
        <div class="info-value">
          <% if @medication.active? %>
            <span style="color: #00ff88;">✓ Active</span>
          <% else %>
            <span style="color: #999;">✗ Inactive</span>
          <% end %>
        </div>
      </div>
      
      <div class="info-item">
        <div class="info-label">Duration</div>
        <div class="info-value">
          <% 
            start_date = @medication.start_date
            end_date = @medication.end_date || Date.today
            days = (end_date - start_date).to_i
          %>
          <%= days %> days
        </div>
      </div>
    </div>
    
    <% if @medication.notes.present? %>
      <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(0, 0, 0, 0.3); border-radius: 10px;">
        <div class="info-label">Notes</div>
        <div style="color: #e0e0e0; margin-top: 0.5rem;"><%= @medication.notes %></div>
      </div>
    <% end %>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📊 Dosage Timeline</h2>
    <div style="position: relative; height: 300px;">
      <canvas id="medicationUsageChart"></canvas>
    </div>
  </div>

  <div class="info-card">
    <h2 style="color: #00d4ff; margin-bottom: 1.5rem;">📝 Dosage History</h2>
    <% if @medication.medication_dosages.any? %>
      <div style="display: grid; gap: 1rem;">
        <% @medication.medication_dosages.ordered.each do |dosage| %>
          <div style="padding: 1.5rem; background: rgba(0, 0, 0, 0.3); border-radius: 10px; border-left: 4px solid #00d4ff; display: flex; justify-content: space-between; align-items: center;">
            <div style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                <div style="color: #00d4ff; font-weight: 600; font-size: 1.3rem;">
                  <%= dosage.dose %> mg
                </div>
                <div style="color: rgba(224, 224, 224, 0.7); font-size: 0.95rem;">
                  📅 <%= dosage.recorded_on.strftime("%B %d, %Y") %>
                </div>
              </div>
              <% if dosage.notes.present? %>
                <div style="color: rgba(224, 224, 224, 0.8); margin-top: 0.5rem; font-size: 0.95rem;">
                  💬 <%= dosage.notes %>
                </div>
              <% end %>
            </div>
            <div style="display: flex; gap: 0.5rem;">
              <%= link_to "✏️", edit_pet_medication_medication_dosage_path(@pet, @medication, dosage), class: "dosage-edit-btn", style: "background: rgba(0, 212, 255, 0.2); border: 1px solid #00d4ff; color: #00d4ff; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-size: 1.2rem; transition: all 0.3s ease;" %>
              <%= button_to "🗑️", pet_medication_medication_dosage_path(@pet, @medication, dosage), method: :delete, class: "dosage-delete-btn", style: "background: rgba(255, 77, 109, 0.2); border: 1px solid #ff4d6d; color: #ff4d6d; padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 1.2rem; transition: all 0.3s ease;", form: { data: { turbo_confirm: "Delete this dosage record?" } } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 2rem; background: rgba(0, 0, 0, 0.2); border-radius: 10px; border: 2px dashed rgba(0, 212, 255, 0.3);">
        <p style="color: rgba(224, 224, 224, 0.5); font-size: 1.1rem;">📋 No dosage history recorded yet.</p>
        <p style="color: rgba(224, 224, 224, 0.4); font-size: 0.9rem; margin-top: 0.5rem;">Add your first dosage record below</p>
      </div>
    <% end %>
    
    <div style="margin-top: 1.5rem; text-align: center;">
      <%= link_to new_pet_medication_medication_dosage_path(@pet, @medication), style: "display: inline-block; color: #00d4ff; text-decoration: none; padding: 1rem 2rem; border: 2px solid #00d4ff; border-radius: 15px; background: rgba(0, 212, 255, 0.1); font-weight: 600; transition: all 0.3s ease;", class: "dosage-add-btn" do %>
        ➕ Add Dosage Change
      <% end %>
    </div>
    
    <style>
      .dosage-add-btn:hover {
        background: #00d4ff !important;
        color: #0a0e27 !important;
      }
      .dosage-edit-btn:hover {
        background: rgba(0, 212, 255, 0.4) !important;
      }
      .dosage-delete-btn:hover {
        background: rgba(255, 77, 109, 0.4) !important;
      }
    </style>
  </div>

  <script>
    (function() {
      function initChart() {
        const canvas = document.getElementById('medicationUsageChart');
        if (!canvas) return;
        
        if (typeof Chart === 'undefined') {
          setTimeout(initChart, 100);
          return;
        }
        
        // Get dosage history - just the change points
        const dosageHistory = <%= raw @medication.medication_dosages.ordered.map { |d| { date: d.recorded_on.strftime('%Y-%m-%d'), dose: d.dose.to_f } }.to_json %>;
        
        if (dosageHistory.length === 0) {
          canvas.parentElement.innerHTML = '<p style="text-align: center; color: rgba(224, 224, 224, 0.5);">No dosage data available</p>';
          return;
        }
        
        // If medication is ongoing (no end_date), add current date with latest dosage
        const medicationEndDate = <%= @medication.end_date ? "new Date('#{@medication.end_date.iso8601}')" : 'null' %>;
        const today = new Date();
        today.setHours(0, 0, 0, 0); // Normalize to start of day
        
        // Get the last dosage entry
        const lastDosage = dosageHistory[dosageHistory.length - 1];
        const lastDate = new Date(lastDosage.date + 'T00:00:00');
        
        // Add today's point if medication is ongoing (no end_date)
        if (!medicationEndDate && lastDate < today) {
          dosageHistory.push({
            date: today.toISOString().split('T')[0],
            dose: lastDosage.dose
          });
        }
        
        // Extract labels and data from dosage history
        const labels = dosageHistory.map(d => {
          const date = new Date(d.date + 'T00:00:00');
          return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        });
        const data = dosageHistory.map(d => d.dose);
        
        const ctx = canvas.getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Dosage (mg)',
              data: data,
              borderColor: '#00d4ff',
              backgroundColor: 'rgba(0, 212, 255, 0.2)',
              fill: true,
              tension: 0.1,
              pointRadius: 6,
              pointHoverRadius: 8,
              pointBackgroundColor: '#00d4ff',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              borderWidth: 3
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: true,
                labels: { color: '#00d4ff', font: { size: 14 } }
              },
              title: {
                display: true,
                text: 'Medication Dosage Over Time',
                color: '#00d4ff',
                font: { size: 18, weight: 'bold' }
              },
              tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#00d4ff',
                bodyColor: '#e0e0e0',
                borderColor: '#00d4ff',
                borderWidth: 2,
                padding: 12,
                callbacks: {
                  label: function(context) {
                    return 'Dosage: ' + context.parsed.y + ' mg';
                  }
                }
              }
            },
            scales: {
              y: {
                beginAtZero: true,
                title: {
                  display: true,
                  text: 'Dosage (mg)',
                  color: '#00d4ff',
                  font: { size: 14, weight: 'bold' }
                },
                ticks: {
                  color: '#e0e0e0',
                  font: { size: 12 },
                  callback: function(value) {
                    return value + ' mg';
                  }
                },
                grid: {
                  color: 'rgba(0, 212, 255, 0.1)',
                  lineWidth: 1
                }
              },
              x: {
                title: {
                  display: true,
                  text: 'Date',
                  color: '#00d4ff',
                  font: { size: 14, weight: 'bold' }
                },
                ticks: {
                  color: '#e0e0e0',
                  font: { size: 11 },
                  maxRotation: 45,
                  minRotation: 45
                },
                grid: {
                  color: 'rgba(0, 212, 255, 0.1)',
                  lineWidth: 1
                }
              }
            }
          }
        });
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initChart);
      } else {
        initChart();
      }
      
      document.addEventListener('turbo:load', initChart);
    })();
  </script>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_pet_medication_path(@pet, @medication), class: "btn-edit" %>
    <%= link_to "📋 Back to Medications", pet_medications_path(@pet), class: "btn-back" %>
    <%= button_to "🗑️ Delete", [@pet, @medication], method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this medication?" } } %>
  </div>
</div>
