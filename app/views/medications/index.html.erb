<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<% content_for :title, "Medications" %>

<style>
  .dashboard-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  
  .dashboard-nav-btn {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 15px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .dashboard-nav-btn:hover {
    background: rgba(0, 212, 255, 0.2);
    border-color: #00d4ff;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    transform: translateY(-3px);
  }
  
  .dashboard-nav-btn.active {
    background: linear-gradient(135deg, #7b2cbf, #5a189a);
    border-color: #9d4edd;
    color: #e0e0e0;
  }
</style>

<div class="page-header">
  <h1>💊 Medications</h1>
  <p class="page-subtitle">Medication tracking for <%= @pet.name %></p>
</div>

<!-- Navigation Tabs -->
<div class="dashboard-nav">
  <%= link_to pet_health_records_path(@pet), class: "dashboard-nav-btn" do %>
    📊 Health Records
  <% end %>
  <%= link_to pet_medications_path(@pet), class: "dashboard-nav-btn active" do %>
    💊 Medications
  <% end %>
  <%= link_to pet_reminders_path(@pet), class: "dashboard-nav-btn" do %>
    ⏰ Reminders
  <% end %>
  <%= link_to dashboard_user_pet_path(@user, @pet), class: "dashboard-nav-btn" do %>
    🏠 Health Dashboard
  <% end %>
</div>

<div style="text-align: center; margin: 1rem 0;">
  <%= link_to "📥 Export to CSV", export_pet_medications_path(@pet, format: :csv), class: "btn-secondary" %>
</div>

<style>
  .medication-list {
    display: grid;
    gap: 1rem;
    margin: 2rem 0;
  }
  
  .medication-item {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    border-radius: 15px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .medication-item:hover {
    border-color: #00d4ff;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
    transform: translateY(-2px);
  }
  
  .medication-item.inactive {
    opacity: 0.6;
    border-color: rgba(128, 128, 128, 0.3);
  }
  
  .medication-info {
    flex: 1;
  }
  
  .medication-name {
    font-size: 1.3rem;
    font-weight: 600;
    color: #00d4ff;
    margin-bottom: 0.5rem;
  }
  
  .medication-details {
    color: rgba(224, 224, 224, 0.8);
    font-size: 0.95rem;
  }
  
  .medication-status {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 15px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-left: 1rem;
  }
  
  .status-active {
    background: rgba(0, 255, 136, 0.2);
    color: #00ff88;
    border: 1px solid #00ff88;
  }
  
  .status-inactive {
    background: rgba(128, 128, 128, 0.2);
    color: #999;
    border: 1px solid #666;
  }
</style>

<h2 style="color: #00d4ff; margin: 2rem 0 1rem 0;">Active Medications</h2>
<div class="medication-list">
  <% if @active_medications.any? %>
    <% @active_medications.each do |medication| %>
      <%= link_to pet_medication_path(@pet, medication), style: "text-decoration: none;" do %>
        <div class="medication-item">
          <div class="medication-info">
            <div class="medication-name">
              💊 <%= medication.medication_name %>
              <span class="medication-status status-active">Active</span>
            </div>
            <div class="medication-details">
              <strong>Dose:</strong> <%= medication.dose %><br>
              <strong>Started:</strong> <%= medication.start_date.strftime("%b %d, %Y") %>
              <% if medication.end_date %>
                | <strong>Ends:</strong> <%= medication.end_date.strftime("%b %d, %Y") %>
              <% end %>
            </div>
          </div>
          <div style="color: #00d4ff; font-size: 1.5rem;">→</div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="empty-state">
      <p>💊 No active medications.</p>
    </div>
  <% end %>
</div>

<h2 style="color: #00d4ff; margin: 2rem 0 1rem 0;">Inactive Medications</h2>
<div class="medication-list">
  <% if @inactive_medications.any? %>
    <% @inactive_medications.each do |medication| %>
      <%= link_to pet_medication_path(@pet, medication), style: "text-decoration: none;" do %>
        <div class="medication-item inactive">
          <div class="medication-info">
            <div class="medication-name">
              💊 <%= medication.medication_name %>
              <span class="medication-status status-inactive">Inactive</span>
            </div>
            <div class="medication-details">
              <strong>Dose:</strong> <%= medication.dose %><br>
              <strong>Period:</strong> <%= medication.start_date.strftime("%b %d, %Y") %> - <%= medication.end_date&.strftime("%b %d, %Y") || "Ongoing" %>
            </div>
          </div>
          <div style="color: rgba(224, 224, 224, 0.5); font-size: 1.5rem;">→</div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="empty-state">
      <p>📋 No inactive medications.</p>
    </div>
  <% end %>
</div>

<div class="floating-action">
  <%= link_to "➕ New Medication", new_pet_medication_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
