<p style="color: green"><%= notice %></p>

<% content_for :title, "Medications" %>

<div class="page-header">
  <h1>💊 Medications</h1>
  <p class="page-subtitle">Medication tracking for <%= @pet.name %></p>
  <div style="margin-top: 10px;">
    <%= link_to "📥 Export to CSV", export_pet_medications_path(@pet, format: :csv), class: "btn-secondary" %>
  </div>
</div>

<% if @medications.any? %>
  <div class="card">
    <h2>Medication Timeline</h2>
    <div style="position: relative; height: 300px;">
      <canvas id="medicationTimelineChart" data-timeline-data="<%= @timeline_data.to_json %>"></canvas>
    </div>
  </div>
<% end %>

<h2>Active Medications</h2>
<div id="active_medications">
  <% @active_medications.each do |medication| %>
    <div class="card">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @active_medications.any? %>">
  <p>💊 No active medications.</p>
</div>

<h2>Inactive Medications</h2>
<div id="inactive_medications">
  <% @inactive_medications.each do |medication| %>
    <div class="card" style="opacity: 0.7;">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @inactive_medications.any? %>">
  <p>📋 No inactive medications.</p>
</div>

<div class="floating-action">
  <%= link_to "➕ New Medication", new_pet_medication_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
