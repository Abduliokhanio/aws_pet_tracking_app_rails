<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<% content_for :title, "Medications" %>

<style>
  .dashboard-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  
  .dashboard-nav-btn {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 15px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .dashboard-nav-btn:hover {
    background: rgba(0, 212, 255, 0.2);
    border-color: #00d4ff;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    transform: translateY(-3px);
  }
  
  .dashboard-nav-btn.active {
    background: linear-gradient(135deg, #7b2cbf, #5a189a);
    border-color: #9d4edd;
    color: #e0e0e0;
  }
</style>

<div class="page-header">
  <h1>💊 Medications</h1>
  <p class="page-subtitle">Medication tracking for <%= @pet.name %></p>
</div>

<!-- Navigation Tabs -->
<div class="dashboard-nav">
  <%= link_to pet_health_records_path(@pet), class: "dashboard-nav-btn" do %>
    📊 Health Records
  <% end %>
  <%= link_to pet_medications_path(@pet), class: "dashboard-nav-btn active" do %>
    💊 Medications
  <% end %>
  <%= link_to pet_reminders_path(@pet), class: "dashboard-nav-btn" do %>
    ⏰ Reminders
  <% end %>
  <%= link_to dashboard_user_pet_path(@user, @pet), class: "dashboard-nav-btn" do %>
    🏠 Health Dashboard
  <% end %>
</div>

<div style="text-align: center; margin: 1rem 0;">
  <%= link_to "📥 Export to CSV", export_pet_medications_path(@pet, format: :csv), class: "btn-secondary" %>
</div>

<% if @medications.any? %>
  <div class="card">
    <h2>Medication Overview</h2>
    <div style="position: relative; height: 300px;">
      <canvas id="medicationTimelineChart"></canvas>
    </div>
  </div>
  
  <script>
    document.addEventListener('turbo:load', () => {
      const canvas = document.getElementById('medicationTimelineChart');
      if (!canvas) return;
      
      const timelineData = <%= raw @timeline_data.to_json %>;
      if (!timelineData || timelineData.length === 0) return;
      
      const ctx = canvas.getContext('2d');
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: timelineData.map(med => med.name),
          datasets: [{
            label: 'Days on Medication',
            data: timelineData.map(med => {
              const start = new Date(med.start);
              const end = new Date(med.end);
              return Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            }),
            backgroundColor: timelineData.map(med => 
              med.active ? 'rgba(0, 212, 255, 0.6)' : 'rgba(128, 128, 128, 0.4)'
            ),
            borderColor: '#00d4ff',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            },
            title: {
              display: true,
              text: 'Medication Duration',
              color: '#00d4ff',
              font: { size: 16 }
            },
            tooltip: {
              backgroundColor: 'rgba(0, 0, 0, 0.8)',
              titleColor: '#00d4ff',
              bodyColor: '#e0e0e0',
              borderColor: '#00d4ff',
              borderWidth: 1,
              callbacks: {
                label: function(context) {
                  const med = timelineData[context.dataIndex];
                  return [
                    `Dose: ${med.dose}`,
                    `Start: ${med.start}`,
                    `End: ${med.end}`,
                    `Status: ${med.active ? 'Active' : 'Inactive'}`
                  ];
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: true,
              title: {
                display: true,
                text: 'Days',
                color: '#00d4ff'
              },
              ticks: { color: '#e0e0e0' },
              grid: { color: 'rgba(0, 212, 255, 0.1)' }
            },
            x: {
              ticks: { 
                color: '#e0e0e0',
                maxRotation: 45,
                minRotation: 45
              },
              grid: { color: 'rgba(0, 212, 255, 0.1)' }
            }
          }
        }
      });
    });
  </script>
<% end %>

<h2>Active Medications</h2>
<div id="active_medications">
  <% @active_medications.each do |medication| %>
    <div class="card">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @active_medications.any? %>">
  <p>💊 No active medications.</p>
</div>

<h2>Inactive Medications</h2>
<div id="inactive_medications">
  <% @inactive_medications.each do |medication| %>
    <div class="card" style="opacity: 0.7;">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @inactive_medications.any? %>">
  <p>📋 No inactive medications.</p>
</div>

<div class="floating-action">
  <%= link_to "➕ New Medication", new_pet_medication_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
