<p style="color: green"><%= notice %></p>

<% content_for :title, "Medications" %>

<style>
  .dashboard-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin: 2rem auto;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  
  .dashboard-nav-btn {
    background: linear-gradient(145deg, rgba(26, 26, 46, 0.8), rgba(22, 33, 62, 0.8));
    border: 2px solid rgba(0, 212, 255, 0.3);
    color: #00d4ff;
    padding: 1rem 2rem;
    border-radius: 15px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .dashboard-nav-btn:hover {
    background: rgba(0, 212, 255, 0.2);
    border-color: #00d4ff;
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
    transform: translateY(-3px);
  }
  
  .dashboard-nav-btn.active {
    background: linear-gradient(135deg, #7b2cbf, #5a189a);
    border-color: #9d4edd;
    color: #e0e0e0;
  }
</style>

<div class="page-header">
  <h1>💊 Medications</h1>
  <p class="page-subtitle">Medication tracking for <%= @pet.name %></p>
</div>

<!-- Navigation Tabs -->
<div class="dashboard-nav">
  <%= link_to pet_health_records_path(@pet), class: "dashboard-nav-btn" do %>
    📊 Health Records
  <% end %>
  <%= link_to pet_medications_path(@pet), class: "dashboard-nav-btn active" do %>
    💊 Medications
  <% end %>
  <%= link_to pet_reminders_path(@pet), class: "dashboard-nav-btn" do %>
    ⏰ Reminders
  <% end %>
  <%= link_to dashboard_user_pet_path(@user, @pet), class: "dashboard-nav-btn" do %>
    🏠 Health Dashboard
  <% end %>
</div>

<div style="text-align: center; margin: 1rem 0;">
  <%= link_to "📥 Export to CSV", export_pet_medications_path(@pet, format: :csv), class: "btn-secondary" %>
</div>

<% if @medications.any? %>
  <div class="card">
    <h2>Medication Timeline</h2>
    <div style="position: relative; height: 300px;">
      <canvas id="medicationTimelineChart" data-timeline-data="<%= @timeline_data.to_json %>"></canvas>
    </div>
  </div>
<% end %>

<h2>Active Medications</h2>
<div id="active_medications">
  <% @active_medications.each do |medication| %>
    <div class="card">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @active_medications.any? %>">
  <p>💊 No active medications.</p>
</div>

<h2>Inactive Medications</h2>
<div id="inactive_medications">
  <% @inactive_medications.each do |medication| %>
    <div class="card" style="opacity: 0.7;">
      <%= render medication %>
      <div class="card-actions">
        <%= link_to "View Details", pet_medication_path(@pet, medication), class: "btn-card" %>
      </div>
    </div>
  <% end %>
</div>

<div class="empty-state" style="<%= 'display: none;' if @inactive_medications.any? %>">
  <p>📋 No inactive medications.</p>
</div>

<div class="floating-action">
  <%= link_to "➕ New Medication", new_pet_medication_path(@pet), class: "btn-floating" %>
  <%= link_to "🐾 Back to Pet", user_pet_path(@user, @pet), class: "btn-floating-secondary" %>
</div>
