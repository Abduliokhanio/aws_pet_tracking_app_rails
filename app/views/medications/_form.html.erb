<%= form_with(model: [pet, medication]) do |form| %>
  <% if medication.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(medication.errors.count, "error") %> prohibited this medication from being saved:</h2>

      <ul>
        <% medication.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :medication_name, style: "display: block" %>
    <%= form.text_field :medication_name, required: true %>
  </div>

  <div>
    <%= form.label :dose, style: "display: block" %>
    <%= form.text_field :dose, required: true, placeholder: "e.g., 10mg twice daily" %>
  </div>

  <div>
    <%= form.label :start_date, style: "display: block" %>
    <%= form.date_field :start_date, required: true, value: medication.start_date || Date.today %>
  </div>

  <div>
    <%= form.label :end_date, "End Date (optional)", style: "display: block" %>
    <%= form.date_field :end_date %>
  </div>

  <div>
    <%= form.label :notes, style: "display: block" %>
    <%= form.text_area :notes, rows: 4, placeholder: "Additional notes about this medication" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
