<% if notice.present? %>
  <p style="color: green"><%= notice %></p>
<% end %>

<div class="show-container">
  <h1><%= @vet_office.name %></h1>
  
  <% if @vet_office.address.present? %>
    <div class="card">
      <h3>Address</h3>
      <p><%= @vet_office.address.formatted %></p>
    </div>
  <% end %>

  <% if @vet_office.contacts.any? %>
    <div class="card">
      <h3>Contact Information</h3>
      <% @vet_office.contacts.each do |contact| %>
        <div style="margin: 10px 0;">
          <strong><%= contact.contact_type.titleize %>:</strong>
          <%= contact.contact_value %>
          <% if contact.is_primary %>
            <span style="color: green;">(Primary)</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @vet_office.veterinarians.any? %>
    <div class="card">
      <h3>Veterinarians</h3>
      <% @vet_office.veterinarians.each do |veterinarian| %>
        <div style="margin: 10px 0; padding: 10px; border-left: 3px solid #4CAF50;">
          <%= link_to veterinarian.name, veterinarian_path(veterinarian) %>
          <% if veterinarian.years_of_experience.present? %>
            <br><small><%= veterinarian.years_of_experience %> years of experience</small>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="action-buttons">
    <%= link_to "✏️ Edit", edit_vet_office_path(@vet_office), class: "btn-edit" %>
    <%= link_to "📋 Back to Vet Offices", vet_offices_path, class: "btn-back" %>
    <%= button_to "🗑️ Delete", @vet_office, method: :delete, class: "btn-delete", form: { data: { turbo_confirm: "Are you sure you want to delete this vet office?" } } %>
  </div>
</div>
